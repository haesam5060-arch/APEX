# ═════════════════════════════════════════════════════════════════
# APEX 환경설정 (NEMESIS R4.2.1 포팅, TRASH=0.30)
# ═════════════════════════════════════════════════════════════════

# 거래모드 (paper-self | paper | real)
TRADING_MODE=paper-self

# 매매 모드 (static_1101 = 옛 R4.1'' / dynamic_v2500k = R4.2.1 동적)
BUY_MODE=dynamic_v2500k

# 동적 매수 거래량 임계 (2,500,000 기본)
VOL_THRESHOLD=2500000

# 시장 필터 (KOSDAQ_ONLY | KOSDAQ_ETF | BOTH)
NEMESIS_MARKET_FILTER=KOSDAQ_ETF

# Python venv 경로
PYTHON_BIN=/Users/sean/Desktop/project/backtest/.venv/bin/python

# uv 바이너리 경로 (poll_minute_vol.py 실행)
UV_BIN=/opt/homebrew/bin/uv

# 저가주 가드 (R4.2.2, 0 = 비활성)
LOW_PRICE_GUARD=1000

# 분봉 데이터 로깅 (0 = 비활성, 1 = 활성)
VOL_TRACE_10S=0

# 전략 설정
TOTAL_CAPITAL=200000
CAPITAL_SHARE=100000
FEE_ROUND_TRIP=0.0035

# KIS API (실전/모의)
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_CANO=your_kis_account_number
KIS_ACNT_PRDT_CD=01

# KIS API (모의투자)
KIS_PAPER_APP_KEY=your_kis_paper_app_key
KIS_PAPER_APP_SECRET=your_kis_paper_app_secret
KIS_PAPER_CANO=your_kis_paper_account_number

# Discord 알림
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Gmail SMTP (이메일 알림)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# 타임존 (Asia/Seoul 고정)
TZ=Asia/Seoul

# 로깅
LOG_LEVEL=info
LOG_DIR=./logs
